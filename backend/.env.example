# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-string-in-production

# Database (overridden by docker-compose service names)
DATABASE_URL=postgresql+asyncpg://agentforge:agentforge_secret@localhost:5432/agentforge

# Redis
REDIS_URL=redis://:agentforge_redis@localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=agentforge_qdrant

# AI  — REQUIRED
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional alternative LLM router
OPENROUTER_API_KEY=

# GitHub (needed for private repos)
GITHUB_TOKEN=

# Storage
REPO_STORAGE_PATH=/app/repos

# Docker sandbox
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=50000

# JWT
JWT_EXPIRE_MINUTES=10080

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
